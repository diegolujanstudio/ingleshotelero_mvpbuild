# ─────────────────────────────────────────────────────────────
# Inglés Hotelero — environment variables
#
# Copy this file to `.env.local` and fill in the values.
# .env.local is gitignored. Never commit secrets.
# See SETUP.md for exactly where each key comes from.
# ─────────────────────────────────────────────────────────────

# ── Supabase (required for auth, database, storage) ──────────
# Project URL, looks like: https://xyzabc.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never expose. Used by API routes for privileged ops.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI: transcription + scoring + content generation ─────────
# Used in Phase 3+. Leave empty for Phase 1.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── WhatsApp delivery (Phase 5) ──────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=     # e.g. whatsapp:+14155238886

# ── Payments (Phase 6) ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Payment Links shown on /precios. Create them in the Stripe dashboard
# (Products → Payment Links) and paste the full URLs here. Until set, the
# CTAs fall back to the pilot-request mailto.
NEXT_PUBLIC_STRIPE_LINK_STARTER=
NEXT_PUBLIC_STRIPE_LINK_PROFESSIONAL=
NEXT_PUBLIC_STRIPE_LINK_ENTERPRISE=

# ── Transactional email (Phase 4+) ───────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@ingleshotelero.com

# ── App config ───────────────────────────────────────────────
# Used for absolute URLs in emails and OG tags.
NEXT_PUBLIC_APP_URL=http://localhost:3000
