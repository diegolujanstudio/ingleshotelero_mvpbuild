<script>
const nav = document.getElementById('nav')!;
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 10);
}, { passive: true });
</script>

<style>
.legal-hero {
  padding: 120px 0 48px;
  background: var(--ivory);
}
.legal-hero h1 {
  font-family: var(--serif);
  font-size: clamp(36px, 5vw, 60px);
  font-weight: 500;
  color: var(--espresso);
  margin: 12px 0 16px;
  line-height: 1.1;
}
.legal-meta {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--espresso-muted);
}
.legal-body {
  padding: 64px 0 120px;
  background: var(--ivory);
}
.legal-content {
  max-width: 720px;
}
.legal-intro {
  font-size: 17px;
  line-height: 1.75;
  color: var(--espresso-soft);
  margin-bottom: 24px;
}
.legal-content h2 {
  font-family: var(--serif);
  font-size: 22px;
  font-weight: 500;
  color: var(--espresso);
  margin: 48px 0 16px;
  padding-top: 8px;
  border-top: 1px solid var(--hair);
}
.legal-content h3 {
  font-family: var(--sans);
  font-size: 15px;
  font-weight: 600;
  color: var(--espresso-soft);
  margin: 24px 0 10px;
}
.legal-content p {
  font-size: 15px;
  line-height: 1.75;
  color: var(--espresso-soft);
  margin-bottom: 16px;
}
.legal-content ul {
  margin: 0 0 20px 20px;
  list-style: disc;
}
.legal-content ul li {
  font-size: 15px;
  line-height: 1.7;
  color: var(--espresso-soft);
  margin-bottom: 8px;
}
.legal-content a {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.legal-content strong {
  color: var(--espresso);
  font-weight: 600;
}
@media (max-width: 640px) {
  .legal-hero { padding: 100px 0 36px; }
  .legal-body { padding: 40px 0 80px; }
}
</style>

</Base>
