---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  currentPage?: 'home' | 'contacto';
}

const {
  title,
  description = 'Inglés Hotelero — Entrenamiento de inglés para equipos de hospitalidad en México.',
  currentPage = 'home',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#F5F0E6" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
  />
</head>
<body data-lang="es" data-page={currentPage}>

  <!-- ── Announcement bar ── -->
  <div class="ann-bar">
    <div class="ann-shell shell">
      <a href="/contacto" class="ann-cta">
        <span class="ann-cta-long">Demo gratuita · 14 días sin costo ni tarjeta</span>
        <span class="ann-cta-short">Demo gratuita</span>
        <span class="ann-arrow">→</span>
      </a>
      <div class="ann-clock" id="annClock" aria-live="off"></div>
    </div>
  </div>

  <slot />

  <script>
    // ─── Announcement bar — CST live clock ───────────────
    function updateAnnClock() {
      const el = document.getElementById('annClock');
      if (!el) return;
      const t = new Intl.DateTimeFormat('en-US', {
        timeZone: 'America/Mexico_City',
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
      }).format(new Date());
      el.textContent = 'CST · ' + t;
    }
    updateAnnClock();
    setInterval(updateAnnClock, 30_000);
  </script>

</body>
</html>
